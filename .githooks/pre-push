#!/usr/bin/env python3
"""Pre-push quality gate.

If publish.py is the caller (.publish.lock exists), all validation
already passed — publish.py would have exited before reaching git push
if any check failed. Allow the push.

If direct git push (no lock), run publish.py --check-only to validate.
Push is blocked unless all checks pass with 0 issues.

Install: git config core.hooksPath .githooks
"""

import subprocess
import sys
from pathlib import Path


def main() -> None:
    repo_root = Path(
        subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
    )
    lock_file = repo_root / ".publish.lock"
    publish_script = repo_root / "scripts" / "publish.py"

    # publish.py is the caller — validation already passed
    if lock_file.exists():
        return

    # Direct git push — run validation
    if not publish_script.is_file():
        print("ERROR: scripts/publish.py not found. Cannot validate.", file=sys.stderr)
        sys.exit(1)

    result = subprocess.run(
        [sys.executable, str(publish_script), "--check-only"],
        cwd=str(repo_root),
    )
    if result.returncode != 0:
        print("\nPush blocked: validation failed.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
