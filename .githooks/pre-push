#!/usr/bin/env python3
"""Pre-push quality gate — delegates all checks to publish.py --check-only.

Install: git config core.hooksPath .githooks
"""

import subprocess
import sys
from pathlib import Path


def main() -> None:
    repo_root = Path(
        subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
    )
    publish_script = repo_root / "scripts" / "publish.py"

    if not publish_script.is_file():
        print("WARNING: scripts/publish.py not found, skipping pre-push checks", file=sys.stderr)
        return

    result = subprocess.run(
        [sys.executable, str(publish_script), "--check-only"],
        cwd=str(repo_root),
    )
    if result.returncode != 0:
        print("\nPre-push checks FAILED. Push blocked.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
