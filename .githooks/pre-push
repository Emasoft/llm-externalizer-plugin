#!/usr/bin/env python3
"""Pre-push quality gate — blocks push if any check fails.

Install: git config core.hooksPath .githooks
"""

import json
import subprocess
import sys
from pathlib import Path


def main() -> None:
    repo_root = Path(
        subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
    )
    mcp_dir = repo_root / "mcp-server"
    plugin_json = repo_root / ".claude-plugin" / "plugin.json"

    print("── Pre-push: TypeScript build check ──")
    result = subprocess.run(["npx", "tsc", "--noEmit"], cwd=str(mcp_dir))
    if result.returncode != 0:
        print("ERROR: TypeScript compilation failed", file=sys.stderr)
        sys.exit(1)

    print("── Pre-push: Manifest check ──")
    try:
        json.loads(plugin_json.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, FileNotFoundError) as e:
        print(f"ERROR: plugin.json invalid: {e}", file=sys.stderr)
        sys.exit(1)

    print("── Pre-push: all checks passed ──")


if __name__ == "__main__":
    main()
