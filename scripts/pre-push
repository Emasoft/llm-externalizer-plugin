#!/usr/bin/env bash
# Pre-push hook — quality gate before code reaches GitHub.
# Blocks the push if there are uncommitted changes or build errors.
# Does NOT modify the repo — no commits, no version bumps, no tags.
#
# Install: ln -sf ../../scripts/pre-push .git/hooks/pre-push
set -euo pipefail

# Resolve repo root (works from .git/hooks/, scripts/hooks/, or direct invocation)
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PUSHING_TO_MAIN=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    PUSHING_TO_MAIN=1
  fi
done

# Only gate pushes to main
if [ "$PUSHING_TO_MAIN" = "0" ]; then
  exit 0
fi

echo ""
echo "========================================"
echo "  Pre-push quality gate"
echo "========================================"
echo ""

# ── 0. Clean working tree ─────────────────────────────────
echo "── 0. Clean working tree ──"
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo ""
  echo "BLOCKED: uncommitted changes found. Commit or stash before pushing."
  git status --short
  exit 1
fi
echo "OK: working tree clean"
echo ""

# ── 1. TypeScript build check ────────────────────────────
echo "── 1. TypeScript build check ──"
cd "$REPO_ROOT/mcp-server"
if [ ! -d "node_modules" ]; then
  echo "  Installing dependencies..."
  npm install --ignore-scripts --silent
fi
npx tsc --noEmit || {
  echo ""; echo "BLOCKED: TypeScript compilation failed."; exit 1
}
cd "$REPO_ROOT"
echo "OK: TypeScript compiles cleanly"
echo ""

# ── 2. Plugin manifest check ────────────────────────────
echo "── 2. Plugin manifest ──"
python3 -c "import json; json.load(open('.claude-plugin/plugin.json', encoding='utf-8'))" || {
  echo ""; echo "BLOCKED: plugin.json is not valid JSON"; exit 1
}
echo "OK: plugin.json valid"
echo ""

echo "========================================"
echo "  All checks passed — pushing"
echo "========================================"
echo ""

exit 0
