# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.ruff_cache/
.mypy_cache/
.pytest_cache/
# uv.lock: scripts/ are stdlib-only (no runtime deps in pyproject.toml),
# so a lockfile adds no value. If deps are ever introduced, remove this
# comment and commit uv.lock alongside them.

# Node
node_modules/
mcp-server/node_modules/
mcp-server/*.tsbuildinfo
mcp-server/*.tgz
mcp-server/coverage/
mcp-server/logs/
mcp-server/llm_externalizer_output/
mcp-server/reports_dev/
reports_dev/
# Audit reports produced by /llm-externalizer:* commands. These contain
# absolute local paths and raw LLM output; never publish to the marketplace.
reports/
mcp-server/reports/

# Build artifacts
dist/
!mcp-server/dist/
build/

# macOS
.DS_Store

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code
.claude/
CLAUDE.md
.tldr/
.tldrignore

# Dev folders (not published)
*_dev/

# Logs
*.log
logs/

# Environment
.env
.env.*

# Security / validation output
security-results/
validation-report.txt

# LLM Externalizer output
llm_externalizer_output/
*.externbak
*.externtmp
*.bak
# TLDR artifacts (added by rechecker)
.tldr_session_*
.publish.lock
